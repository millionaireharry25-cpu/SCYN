{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "lastSeen": { "type": "string", "format": "date-time" },
        "wallpaper": { "type": "string" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Represents a one-to-one or group chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["private", "group"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "name": { "type": "string" },
        "groupPhoto": { "type": "string" }
      },
      "required": ["id", "type", "participants"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video", "file", "voice"] },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "delivered", "seen"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "reactions": { "type": "object" }
      },
      "required": ["chatId", "senderId", "type", "createdAt"]
    },
    "Note": {
      "title": "Personal Note",
      "description": "User's personal notes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "content": { "type": "string" },
        "isPinned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/chats/{chatId}": { "schema": "Chat", "description": "Chat sessions" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Messages within a chat" },
    "/notes/{noteId}": { "schema": "Note", "description": "User personal notes" }
  }
}
